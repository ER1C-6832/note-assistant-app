# Notes API
NOTES_API_BASE_URL=http://127.0.0.1:18080

# py-xiaozhi external runtime.
# Keep the full py-xiaozhi repository outside note-assistant-app.
PY_XIAOZHI_ROOT=C:\yuyinzhushou\py-xiaozhi-tao
PY_XIAOZHI_MODE=cli
PY_XIAOZHI_PROTOCOL=websocket

# Optional. Leave empty to auto-detect:
#   %PY_XIAOZHI_ROOT%\.venv\Scripts\python.exe
#   %PY_XIAOZHI_ROOT%\venv\Scripts\python.exe
#   python from PATH
PY_XIAOZHI_PYTHON=

# Optional. Set to 1 only for local debugging when you want to bypass activation.
PY_XIAOZHI_SKIP_ACTIVATION=0

# Sidecar reserved for Phase 5.1+
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=17890
SIDECAR_WS_URL=ws://127.0.0.1:17890/assistant
