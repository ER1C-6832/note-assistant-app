# Notes API
NOTES_API_BASE_URL=http://127.0.0.1:18080
NOTES_API_HOST=127.0.0.1
NOTES_API_PORT=18080

# SQLite database path
NOTES_DB_PATH=./services/notes-api/data/notes.db

# py-xiaozhi external runtime
PY_XIAOZHI_ROOT=C:\yuyinzhushou\py-xiaozhi-tao
PY_XIAOZHI_MODE=cli
PY_XIAOZHI_PROTOCOL=websocket
PY_XIAOZHI_PYTHON=

# Optional. If omitted, Sidecar tries LOCALAPPDATA\py-xiaozhi\py-xiaozhi\logs\app.log
PY_XIAOZHI_LOG_PATH=

# PC Assistant Sidecar
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=17890
SIDECAR_WS_PORT=17890
SIDECAR_HEALTH_HOST=127.0.0.1
SIDECAR_HEALTH_PORT=17891
SIDECAR_WS_URL=ws://127.0.0.1:17890/assistant
SIDECAR_NOTES_POLL_SECONDS=2.0
SIDECAR_LOG_POLL_SECONDS=1.0
